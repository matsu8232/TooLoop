<div class="cover-item-show">
    <div class="container d-flex flex-column align-items-center">
        <div class="row mt-3 w-100 justify-content-center text-center text-md-start">
            <div class="col-12 col-lg-10">
                <h1 class="mb-0">備品詳細</h1>
            </div>
        </div>
        <div class="row mt-4 mt-lg-5 w-100 justify-content-center g-4">
            <div class="col-12 col-lg-6">
                <p class="caption"><%= @item.name %></p>
                <% if @item.image.attached? %>
                    <%= image_tag @item.image.variant(resize_to_limit: [450, 350]) %><br>
                <% else %>
                    <%= image_tag 'no_image.jpg', size: "450x350" %>
                <% end %>
                <p id="text">【備品の説明】</p>
                <%= @item.description %>
                <p id="text">【所有課】<%= link_to @item.user.name, user_path(@item.user) %></p>
                <p id="text">【カテゴリ】<%= @item.category.name %></p>
                <p id="text">【状態】<%= t("enums.item.status.#{@item.status}") %></p>
                <% if @item.user == current_user %>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <%= link_to '編集する', edit_item_path(@item.id), class: "btn btn-info" %>
                        <%= link_to '削除する', item_path(@item.id), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn btn-danger" %>
                    </div>
                <% end %>
                <%= link_to '備品一覧へ', items_path, class: "btn btn-dark mt-3" %>
            </div>
            <div class="col-12 col-lg-5">
                <div class="calendar">
                    <%= month_calendar do |date| %>
                        <%= date.day %>
                        <% if date >= @from && date <= @to && date.on_weekday? %>
                            <% if reserved_on?(@reserved_dates, date) %>
                                <div class="small text-danger">予約済</div>
                            <% else %>
                                <div class="small text-success">◯</div>
                            <% end %>
                        <% elsif date >= @from && date <= @to %>
                            <div class="small text-muted">対象外</div>
                        <% end %>
                    <% end %>
                    <div class="mt-3 text-center text-md-end">
                        <% if user_signed_in? && @item.user == current_user %>
                            <%= link_to '予約受付状況の確認', item_reservations_path(@item), class: 'btn btn-outline-primary' %>
                        <% elsif @item.maintenance? %>
                            <span class="text-danger d-inline-block text-start">現在、メンテナンス中のため予約できません。</span>
                        <% else %>
                            <%= link_to 'この備品を予約する', item_reservations_path(@item), class: 'btn btn-primary' %>
                        <% end %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
