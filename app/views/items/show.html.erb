<div class="cover-show">
    <div class="container">
        <div class="row">
            <h1 class="font-weight-normal mt-5 mb-5">備品詳細</h1>
        </div>
        <div class="d-flex">
            <div class="d-block">
                <p class="caption"><%= @item.name %></p>
                <% if @item.image.attached? %>
                    <%= image_tag @item.image.variant(resize_to_limit: [450, 350]) %><br>
                <% else %>
                    <%= image_tag 'no_image', size: "450x350" %>
                <% end %>
                <h2>所有課</h2>
                <%= link_to @item.user.name, user_path(@item.user) %><br>
                <h2>備品の説明</h2>
                <p><%= @item.description %></p>
                <h2>カテゴリ</h2>
                <p><%= @item.category.name %></p>
                <h2>状態</h2>
                <p><%= t("enums.item.status.#{@item.status}") %></p>
                <% if @item.user == current_user %>
                    <%= link_to '編集する', edit_item_path(@item.id) %><br>
                    <%= link_to '削除する', item_path(@item.id), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %><br>
                <% end %>
                <%= link_to '備品一覧へ', items_path %>
            </div>
            <div class="calendar ml-5 mt-5">
                <%= month_calendar do |date| %>
                    <%= date %>
                <% end %>
            </div>
        </div>
    </div>
</div>
