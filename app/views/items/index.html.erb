<div class="cover-item-index">
    <div class="container d-flex flex-column align-items-center">
        <div class="row mt-3">
            <h1>備品一覧</h1>
        </div>
        <div class="row mt-3 mb-5 w-100 justify-content-center justify-content-md-end">
            <div class="col-12 col-md-auto">
                <%= form_with url: items_path, method: :get, local: true, html: { class: "item-index-search w-100 text-center text-md-start" } do |f| %>
                    <div class="category-filter">
                        <p class="form-label fw-bold small">カテゴリで絞り込み</p>
                        <% @categories.each do |category| %>
                            <label class="mr-2">
                                <%= check_box_tag 'category_ids[]', category.id, params[:category_ids]&.map(&:to_i)&.include?(category.id) %>
                                <%= category.name %>
                            </label>
                        <% end %>
                        <%= f.submit '絞り込む', name: nil, class: "btn btn-sm btn-primary rounded-pill mb-1" %>
                    </div>
                    <div class="keyword-filter mt-2 w-100">
                        <p class="form-label fw-bold small">キーワードで検索</p>
                        <div class="keyword-filter-controls d-flex flex-md-row gap-2 align-items-end align-items-md-center">
                            <%= f.text_field :keyword, value: params[:keyword], placeholder: "キーワードを入力してください", class: "form-control flex-grow-1 min-w-0" %>
                            <%= f.submit '検索', name: nil, class: "btn btn-sm btn-primary rounded-pill flex-shrink-0" %>
                        </div>
                        <% if @items.empty? %>
                            <p class="text-danger">「<%= params[:keyword]%>」に一致するものはありませんでした。</p>
                        <% end %>
                    </div>
                <% end %>
            </div>
        </div>
        <div class="row g-4 mb-3 index-left w-100">
            <% @items.each do |item| %>
                <div class="one-post col-12 col-sm-4">
                    <%= link_to item_path(item) do %>
                        <p class="caption"><%= item.user.name %></p>
                        <% if item.image.attached? %>
                            <%= image_tag item.image.variant(resize_to_limit: [300, 200]) %>
                        <% else %>
                            <%= image_tag 'no_image.jpg', size: "300x200" %>
                        <% end %>
                        <p class="caption"><%= item.name %></p>
                    <% end %>
                    <%= t("enums.item.status.#{item.status}") %>
                </div>
            <% end %>
        </div>
        <%= paginate @items %>
    </div>
</div>