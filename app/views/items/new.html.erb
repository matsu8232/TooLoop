<div class="cover-item-new">
    <div class="container d-flex flex-column align-items-center">
        <div class="row mt-3">
            <h1>備品登録</h1>
        </div>
        <% if @item.errors.any? %>
            <div class="card text-center text-white bg-danger mt-3">
                <%= @item.errors.count %>件のエラーが発生しました
                <% @item.errors.full_messages.each do |message| %>
                    <%= message %>
                <% end %>
            </div>
        <% end %>
        <div class="row mt-5">
            <%= form_with model: @item, local: true do |f| %>
                <div class="form-group mb-3">
                    <label class="form-label">【備品名】</label>
                    <%= f.text_field :name, class: "form-control" %>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">【備品の説明】</label>
                    <%= f.text_area :description, rows: 10, class: "form-control" %>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">【画像】</label><br>
                    <%= f.file_field :image %>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">【カテゴリ】</label><br>
                    <%= f.collection_select :category_id, Category.all, :id, :name %>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">【状態】</label><br>
                    <%= f.select :status, Item.statuses.keys.map { |k| [t("enums.item.status.#{k}"), k] }, {}, { class: "custom-select w-25 mb-3" } %><br>
                </div>
                <%= f.submit '登録する', class: 'btn btn-success' %>
            <% end %>
        </div>
    </div>
</div>