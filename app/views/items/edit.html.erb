<div class="cover-item-edit">
    <div class="container">
        <div class="row">
            <h1 class="mt-3 mb-5">備品編集</h1>
        </div>
        <% if @item.errors.any? %>
            <div class="card text-center text-white bg-danger mt-3">
                <%= @item.errors.count %>件のエラーが発生しました
                <% @item.errors.full_messages.each do |message| %>
                    <%= message %>
                <% end %>
            </div>
        <% end %>
        <div class="row">
            <%= form_with model: @item, local: true do |f| %>
                <div class="form-group mb-3">
                    <label class="form-label">備品名</label>
                    <%= f.text_field :name, class: "form-control" %>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">備品の説明</label>
                    <%= f.text_area :description, rows: 10, class: "form-control" %>
                </div>
                <div class="form-group mb-4">
                    <label class="form-label">画像</label><br>
                    <% if @item.image.attached? %>
                        <%= image_tag @item.image.variant(resize_to_limit: [450, 350]) %><br>
                    <% else %>
                        <%= image_tag 'no_image', size: "450x350" %><br>
                    <% end %>
                    <label class="form-label">画像を変更する</label><br>
                    <%= f.file_field :image %><br>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">カテゴリ</label>
                    <%= f.collection_select :category_id, Category.all, :id, :name %>
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">状態</label>
                    <%= f.select :status, Item.statuses.keys.map { |k| [t("enums.item.status.#{k}"), k] }, {}, { class: "form-select item-status-select mb-3" } %><br>
                </div>
                <%= f.submit '更新', class: 'btn btn-success' %><br>
                <%= link_to '備品詳細ページへ', item_path(@item), class: "btn btn-dark mt-3" %>
            <% end %>
        </div>
    </div>
</div>