<div class="cover-item-edit">
    <div class="container">
        <h1>備品編集</h1>
        <% if @item.errors.any? %>
            <div class="card text-center text-white bg-danger mt-3">
                <%= @item.errors.count %>件のエラーが発生しました
                <% @item.errors.full_messages.each do |message| %>
                    <%= message %>
                <% end %>
            </div>
        <% end %>
        <%= form_with model: @item, local: true do |f| %>
            <h4>備品名</h4>
            <%= f.text_field :name %>
            <h4>備品の説明</h4>
            <%= f.text_area :description %>
            <h4>画像</h4>
            <% if @item.image.attached? %>
                <%= image_tag @item.image.variant(resize_to_limit: [450, 350]) %><br>
            <% else %>
                <%= image_tag 'no_image', size: "450x350" %><br>
            <% end %>
            <h4>画像を変更する</h4>
            <%= f.file_field :image %><br>
            <h4>カテゴリ</h4>
            <%= f.collection_select :category_id, Category.all, :id, :name %>
            <h4>状態</h4>
            <%= f.select :status, Item.statuses.keys.map { |k| [t("enums.item.status.#{k}"), k] }, {}, { class: "custom-select w-25 mb-3" } %><br>
            <%= f.submit '更新', class: 'btn btn-success' %>
        <% end %>
    </div>
</div>