<!DOCTYPE html>
<html>
  <head>
    <title>TooLoop</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag 'favicon.ico' %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar sticky-top" aria-label="サイトメインメニュー" data-controller="navbar-toggle">
      <div class="container-fluid px-3">
        <%= link_to "TooLoop", root_path, class: "navbar-brand mb-0 fw-bold text-white" %>
        <button class="navbar-toggler app-navbar-toggler border-0 shadow-none"
                type="button"
                data-navbar-toggle-target="toggler"
                data-action="click->navbar-toggle#toggle"
                aria-controls="appNavbarMain"
                aria-expanded="false"
                aria-label="メニューを開く">
          <span class="app-navbar-toggler-bars" aria-hidden="true">
            <span class="app-navbar-toggler-bar"></span>
            <span class="app-navbar-toggler-bar"></span>
            <span class="app-navbar-toggler-bar"></span>
          </span>
          <span class="app-navbar-toggler-label" data-navbar-toggle-target="label">メニュー</span>
        </button>
        <div id="appNavbarMain" class="collapse navbar-collapse" data-navbar-toggle-target="menu">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1">
            <li class="nav-item">
              <%= link_to "備品検索", items_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "備品登録", new_item_path, class: "nav-link" %>
            </li>
            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to "マイページ", user_path(current_user.id), class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "ログイン", new_user_session_path, class: "nav-link" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>
    <% flash.each do |message_type, message| %>
      <div class="alert alert-<%= message_type == 'notice' ? 'success' : 'danger' %>">
        <%= message %>
      </div>
    <% end %>
    <% if show_breadcrumbs? %>
      <nav aria-label="breadcrumb" class="app-breadcrumb">
        <ol class="breadcrumb mb-0">
          <% breadcrumbs.each_with_index do |crumb, index| %>
            <% is_last = index == breadcrumbs.length - 1 %>
            <% if is_last || crumb[:path].blank? %>
              <li class="breadcrumb-item active" aria-current="page"><%= crumb[:label] %></li>
            <% else %>
              <li class="breadcrumb-item"><%= link_to crumb[:label], crumb[:path] %></li>
            <% end %>
          <% end %>
        </ol>
      </nav>
    <% end %>
    <main class="app-main">
      <%= yield %>
    </main>
  </body>
</html>
