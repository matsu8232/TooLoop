<!DOCTYPE html>
<html>
  <head>
    <title>TooLoop</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag 'favicon.ico' %>
  </head>

  <body>
    <header>
      <div class="header-logo">
        <%= link_to "TooLoop", root_path, class: "text-white nav-link" %>
      </div>
      <div class="header-menu">
        <%= link_to "備品検索", items_path, class: "nav-item" %>
        <%= link_to "備品登録", new_item_path, class: "nav-item" %>
        <% if user_signed_in? %>
          <%= link_to "マイページ", user_path(current_user.id), class: "nav-item" %>
          <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-item" %>
        <% else %>
          <%= link_to "ログイン", new_user_session_path, class: "nav-item" %>
        <% end %>
      </div>
    </header>
    <% flash.each do |message_type, message| %>
      <div class="alert alert-<%= message_type == 'notice' ? 'success' : 'danger' %>">
        <%= message %>
      </div>
    <% end %>
    <% if show_breadcrumbs? %>
      <nav aria-label="breadcrumb" class="app-breadcrumb">
        <ol class="breadcrumb mb-0">
          <% breadcrumbs.each_with_index do |crumb, index| %>
            <% is_last = index == breadcrumbs.length - 1 %>
            <% if is_last || crumb[:path].blank? %>
              <li class="breadcrumb-item active" aria-current="page"><%= crumb[:label] %></li>
            <% else %>
              <li class="breadcrumb-item"><%= link_to crumb[:label], crumb[:path] %></li>
            <% end %>
          <% end %>
        </ol>
      </nav>
    <% end %>
    <%= yield %>
  </body>
</html>
