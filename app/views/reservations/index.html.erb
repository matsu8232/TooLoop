<div class="cover-reservation-index">
  <div class="container d-flex flex-column align-items-center">
    <div class="row mt-3">
      <h1 class="font-weight-normal">予約カレンダー：<%= @item.name %></h1>
    </div>
    <p class="mb-4">土日を除いて最大5日間、1ヶ月先まで予約できます。予約開始日を選択してください。</p>
    <div class="row">
      <div class="col-12">
        <%= month_calendar do |date| %>
          <%= date.day %>
          <% if date >= @from && date <= @to && date.on_weekday? %>
            <% if reserved_on?(@reserved_dates, date) %>
              <div class="small text-danger">予約済</div>
            <% else %>
              <% if @item.user == current_user %>
                <div class="small text-success">◯</div>
              <% else %>
                <%= link_to "◯", new_item_reservation_path(@item, start_date: date, end_date: date), class: "small" %>
              <% end %>
            <% end %>
          <% elsif date >= @from && date <= @to %>
            <div class="small text-muted">対象外</div>
          <% end %>
        <% end %>
      </div>
      <%= link_to "備品詳細に戻る", item_path(@item), class: "btn btn-outline-secondary" %>
    </div>
    <div class="history-group mt-3 mb-3">
      <% if @item.user == current_user %>
        <h3 class="font-weight-normal">予約受付状況</h3>
        <% if @reservations.any? %>
          <table class="table">
            <thead>
              <tr>
                <th>開始日</th>
                <th>終了日</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @reservations.each do |reservation| %>
                <tr>
                  <td><%= reservation.start_date %></td>
                  <td><%= reservation.end_date %></td>
                  <td><%= link_to "詳細", item_reservation_path(@item, reservation), class: "btn btn-sm btn-outline-primary" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p>現在、予約している人はいません。</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>