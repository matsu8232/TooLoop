<div class="container">
  <div class="row">
    <h1 class="font-weight-normal mt-5 mb-5">予約カレンダー：<%= @item.name %></h1>
  </div>
  <p class="mb-4">土日を除いて最大5日間、1ヶ月先まで予約できます。予約開始日を選択してください。</p>
  <div class="row">
    <div class="col-12">
      <% from = Date.current + 1 %>
      <% to = Date.current >> 1 %>
      <% reserved_dates = Reservation.reserved_dates_for_item(@item, from: from, to: to) %>
      <%= month_calendar do |date| %>
        <%= date.day %>
        <% if date >= from && date <= to && date.wday != 0 && date.wday != 6 %>
          <% if reserved_on?(reserved_dates, date) %>
            <div class="small text-danger">予約済</div>
          <% else %>
            <%= link_to "予約", new_item_reservation_path(@item, start_date: date, end_date: date), class: "small" %>
          <% end %>
        <% elsif date >= from && date <= to %>
          <div class="small text-muted">土日</div>
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="row mb-4">
    <%= link_to "備品詳細に戻る", item_path(@item), class: "btn btn-outline-secondary ms-2" %>
  </div>
  <% if @reservations.any? %>
    <div class="row mt-5">
      <h2>予約一覧</h2>
      <table class="table">
        <thead>
          <tr>
            <th>開始日</th>
            <th>終了日</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @reservations.each do |reservation| %>
            <tr>
              <td><%= reservation.start_date %></td>
              <td><%= reservation.end_date %></td>
              <td>
                <%= link_to "詳細", item_reservation_path(@item, reservation), class: "btn btn-sm btn-outline-primary" %>
                <% if reservation.user_id == current_user&.id %>
                  <%= button_to "キャンセル", item_reservation_path(@item, reservation), method: :delete, form: { data: { turbo_confirm: "予約をキャンセルしますか？" } }, class: "btn btn-sm btn-outline-danger" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
