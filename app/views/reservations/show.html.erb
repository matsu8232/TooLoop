<div class="cover-reservation-show">
  <div class="container d-flex flex-column align-items-center">
    <div class="row mt-3">
      <h1>予約詳細</h1>
    </div>
    <div class="row">
      <div class="d-block">
        <p id="text"><strong>備品：</strong><%= @item.name %></p>
        <p id="text"><strong>開始日：</strong><%= @reservation.start_date %></p>
        <p id="text"><strong>終了日：</strong><%= @reservation.end_date %></p>
        <p id="text"><strong>予約した人：</strong><%= link_to @reservation.user.name, user_path(@reservation.user) %></p>
      </div>
      <div class="d-flex flex-column flex-sm-row flex-wrap gap-2 mt-3">
        <%= link_to "備品詳細へ", item_path(@item), class: "btn btn-outline-dark" %>
        <% if current_user == @reservation.item.user %>
          <%= link_to '予約した人とチャットを始める', chat_path(@reservation.user.id), class: "btn btn-outline-primary" %>
        <% else %>
          <%= link_to '所有者とチャットを始める', chat_path(@reservation.item.user.id), class: "btn btn-primary" %>
          <%= button_to "予約をキャンセル", item_reservation_path(@item, @reservation), method: :delete, form: { data: { turbo_confirm: "予約をキャンセルしますか？" }, class: "d-inline" }, class: "btn btn-danger" %>
        <% end %>
      </div>
    </div>
  </div>
</div>