<div id="chat_<%= chat.id %>" class="right-container d-flex justify-content-end mb-3 chat-item">
    <div class="d-flex align-items-baseline">
        <p class="chat-bubble chat-bubble--me">
            <%= chat.message %>
        </p>
        <div class="delete-button-wrapper">
            <%= button_to "×", chat_path(chat), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "btn btn-danger btn-sm" %>
        </div>
    </div>
</div>