<div class="bg">
  <div class="login-card">
    <div class="login-card-inner">
      <%= form_with model: @user, url: user_session_path, local: true do |f| %>
        <h1 class="login-title">ログイン</h1>

        <div class="field-group">
          <%= f.label :email, "Eメール", class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "example@mail.com" %>
        </div>

        <div class="field-group">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <%= f.label :password, "パスワード", class: "form-label mb-0" %>
            <%= link_to "パスワードを忘れた場合", new_user_password_path, class: "help-link" %>
          </div>
          <%= f.password_field :password, autocomplete: "current-password", class: "form-input", placeholder: "••••••••" %>
        </div>

        <div class="login-action">
          <%= f.submit "ログイン", class: "btn-login" %>
          <% if devise_mapping.rememberable? %>
            <div class="remember-me">
              <%= f.check_box :remember_me %>
              <%= f.label :remember_me, "ログイン状態を保持する" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="new-user-section">
        <div class="divider">
          <span>新しいお客様ですか？</span>
        </div>
        <%= link_to "アカウントを作成する", new_user_registration_path, class: "btn-signup" %>
      </div>
    </div>
  </div>
</div>